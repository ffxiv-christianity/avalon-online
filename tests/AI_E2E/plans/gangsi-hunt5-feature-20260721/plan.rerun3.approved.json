  "questionnaire": {
    "schemaVersion": "1.0",
    "answers": {
      "game": "gangsi",
      "testType": "feature_cp",
      "objective": "Verify all 20 declared five-player Gangsi Hunt checkpoints through three approved visible-UI journeys while preserving player information isolation and consistent terminal results.",
      "userPerspective": "experienced_player",
      "focusAreas": [
        "settings",
        "core_gameplay",
        "information_isolation",
        "result_consistency"
      ],
      "journeyIntent": "Execute all three required Hunt routes: fixed classic trap/core/escape, fixed test-map invisible/last-survivor, and random-map knife targeted coverage.",
      "scenarioIntent": "Use the Adapter-declared trap, invisible, and knife route scenarios; keep all unrelated player decisions autonomous.",
      "playerCount": 5,
      "gamesToPlay": 3,
      "gameSettings": {
        "mode": "hunt",
        "mapSchedule": [
          "fixed:classic",
          "fixed:test-map",
          "random"
        ]
      },
      "speedProfile": {
        "profile": "fast",
        "operationDelayMs": 0,
        "pollIntervalMs": 100,
        "serverTimeScale": 1,
        "narration": "milestones",
        "timingFidelity": "production"
      },
      "reconnectMode": "none",
      "playerBehavior": "Five persistent isolated experienced-player agents make bounded plausible decisions from only their own visible observations; the Adapter controls only the approved route setup and checkpoint actions.",
      "completionStatement": "All three approved routes are completed in order: journey 1 reaches the adventurer terminal, journey 2 reaches the mummy terminal, and journey 3 records sufficient knife checkpoint evidence at knife_cp_complete.",
      "passRules": [
        {
          "id": "all_hunt_checkpoints_visible",
          "description": "Every one of the 20 declared Hunt checkpoints has scoped visible evidence, every declared sub-assertion is true, and the matching checkpoint_result passes within its approved route.",
          "oracle": "visible_ui"
        },
        {
          "id": "hunt_information_isolated",
          "description": "No player tab or agent receives another player's mission, hidden position, trap position, or actor-only ability state.",
          "oracle": "visible_ui"
        },
        {
          "id": "hunt_terminals_consistent",
          "description": "The two terminal routes show identical normalized winner, escape/death totals, adventurer rows, and mummy row across all five tabs.",
          "oracle": "cross_tab_consistency"
        }
      ],
      "failRules": [
        {
          "id": "identity_or_isolation_failure",
          "description": "Any player/session/tab swap, secret transfer, decision from undisclosed private facts, or non-UI gameplay action occurs.",
          "severity": "P0"
        },
        {
          "id": "hunt_checkpoint_or_consistency_failure",
          "description": "Any illegal target is offered or accepted; checkpoint timing or state is wrong; terminal rows differ; a target CP lacks completed-route and passing evidence; or deployed fingerprint changes.",
          "severity": "P1"
        }
      ],
      "notEvaluated": [
        "Classic mode",
        "Player counts other than five",
        "Maps outside the approved three-journey schedule",
        "Rules window and map editor",
        "Reconnect behavior",
        "Balance and production countdown duration"
      ],
      "stopConditions": [
        "The user interacts with a Run-owned tab",
        "Any isolated player context is unavailable",
        "The same decision is illegal three consecutive times",
        "The deployed service or semantic UI is unavailable",
        "Continuation would require changing Gangsi product code",
        "Any journey exceeds 180 minutes"
      ],
      "evidenceReuse": {
        "policy": "require_new_run",
        "requireCurrentBuild": true,
        "requireProductionTiming": false
      },
      "checkpointCoverage": {
        "mode": "all_declared",
        "checkpointIds": []
      }
    },
    "delegatedFields": [],
    "unanswered": [],
    "conflicts": []
  },
